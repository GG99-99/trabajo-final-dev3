<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Platforms>x86;x64</Platforms>
    <!-- U.are.U SDK requires x86 or x64 — NOT AnyCPU -->
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <!-- DigitalPersona U.are.U .NET SDK -->
  <ItemGroup>
    <Reference Include="DPUruNet">
      <HintPath>libs\DPUruNet.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DPCtlUruNet">
      <HintPath>libs\DPCtlUruNet.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
